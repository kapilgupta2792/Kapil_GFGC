tin typeface="Aptos"/><a:ea typeface="Calibri Black"/></a:rPr><a:t>Our Engagement Models with Clients</a:t></a:r><a:endParaRPr lang="en-US" sz="2200" b="1"><a:latin typeface="Aptos"/><a:ea typeface="Calibri Black"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="135" name="Shape 2"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{785BA817-C69D-2A42-E134-909935A031BF}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="320040" y="521208"/><a:ext cx="8503920" cy="18288"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:solidFill><a:srgbClr val="BFBFBF"/></a:solidFill><a:ln w="12700"><a:solidFill><a:srgbClr val="BFBFBF"/></a:solidFill><a:prstDash val="solid"/></a:ln></p:spPr><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:endParaRPr lang="en-IN"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="3" name="Text 5"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{26CACB74-EF07-17FC-3E5B-F468C77954F4}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="3084087" y="773466"/><a:ext cx="2655739" cy="368046"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln/></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1500"><a:solidFill><a:srgbClr val="404040"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>Supervision &amp; Monitoring Layer</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1000"><a:solidFill><a:srgbClr val="404040"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>Execution focused support</a:t></a:r><a:endParaRPr lang="en-US" sz="1000"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="4" name="Text 15"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{D8E98A26-2DC9-DA00-F4EB-0E1CF4CC6F70}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="6058411" y="696145"/><a:ext cx="3039869" cy="530379"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln/></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1500"><a:solidFill><a:srgbClr val="404040"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>Operations Take Over </a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1000"><a:solidFill><a:srgbClr val="404040"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>with 1% Fraud Indemnity and Amortization Benefit  </a:t></a:r><a:endParaRPr lang="en-US" sz="1000"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="5" name="Text 5"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{3629CFC8-232A-5027-3374-E220CCCE829F}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="320040" y="773465"/><a:ext cx="2445462" cy="386929"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln/></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1500"><a:solidFill><a:srgbClr val="404040"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>Strategic Advisory</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="1000"><a:solidFill><a:srgbClr val="404040"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>Structured, Outcome-Oriented Advisory</a:t></a:r><a:endParaRPr lang="en-US" sz="1000"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="9" name="Flowchart: Process 8"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{5E4EB65B-1FD5-36D9-9783-05B3BB32C5C8}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="3084087" y="1226169"/><a:ext cx="2558430" cy="2691161"/></a:xfrm><a:prstGeom prst="flowChartProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="50000"/></a:schemeClr></a:solidFill><a:ln/></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We deploy senior leaders along with key L-1 experts to oversee Operations / Collections.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>These leaders work with the existing Ops Head / Collections Head, supporting day-to-day decisions and actions.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>This is </a:t></a:r><a:r><a:rPr lang="en-US" sz="1200" b="1"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>not</a:t></a:r><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t> a PMO layer, but an </a:t></a:r><a:r><a:rPr lang="en-US" sz="1200" b="1"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>execution layer - </a:t></a:r><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>working as a +1 to existing leaders to ensure progress toward defined KPIs.</a:t></a:r><a:endParaRPr lang="en-IN" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="10" name="Flowchart: Process 9"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{1566F90D-A630-50E4-B0C9-C010F4EDE071}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="3084087" y="4054434"/><a:ext cx="2558430" cy="904534"/></a:xfrm><a:prstGeom prst="flowChartProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="50000"/></a:schemeClr></a:solidFill><a:ln/></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="t"/><a:lstStyle/><a:p><a:r><a:rPr lang="en-IN" sz="1200" b="1"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Benefits –</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1100"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Limited organizational disruption</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1100"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Low regulatory risk</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1100"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Builds internal capability</a:t></a:r><a:endParaRPr lang="en-IN" sz="1100"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-IN" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="12" name="Flowchart: Process 11"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{E706C793-2270-9353-A84D-5ED469F88B15}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="6058410" y="1224404"/><a:ext cx="2765549" cy="2691161"/></a:xfrm><a:prstGeom prst="flowChartProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="50000"/></a:schemeClr></a:solidFill><a:ln/></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We take over Operations along with regulatory-mandated activities in coordination with the client.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We maintain direct control over a defined employee pool and operate as a managed services partner.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Commercials structured at a % of Opex or new disbursements, whichever is higher.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We provide fraud indemnification of up to 1% of AUM for business disbursed under our supervision, along with amortization benefits.</a:t></a:r><a:endParaRPr lang="en-IN" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="13" name="Flowchart: Process 12"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{60E5EAB9-0843-E8A2-9C69-EFBB725573D5}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="6058411" y="4047000"/><a:ext cx="2765548" cy="904534"/></a:xfrm><a:prstGeom prst="flowChartProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="50000"/></a:schemeClr></a:solidFill><a:ln/></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="t"/><a:lstStyle/><a:p><a:r><a:rPr lang="en-IN" sz="1200" b="1"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Benefits -</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Fixed cost structure with </a:t></a:r><a:r><a:rPr lang="en-US" sz="1050" err="1"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>IndAS</a:t></a:r><a:r><a:rPr lang="en-US" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t> benefit </a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>FLDG enabling confidence to scale </a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Clear ownership and accountability (“one neck to choke”) </a:t></a:r></a:p><a:p><a:endParaRPr lang="en-IN" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="14" name="Flowchart: Process 13"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{6FE7A513-F9FE-1AD5-76FF-56CFE1B89AF8}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="310275" y="1224403"/><a:ext cx="2350484" cy="2691161"/></a:xfrm><a:prstGeom prst="flowChartProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="50000"/></a:schemeClr></a:solidFill><a:ln/></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We partner with your leadership to diagnose growth constraints, redesign operating models, and define a clear performance roadmap across credit, operations, and collections.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-US" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>The engagement enables execution through guidance, reviews, and KPI alignment, without altering existing structures.</a:t></a:r><a:endParaRPr lang="en-IN" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="15" name="Flowchart: Process 14"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{38CA6B9C-A0D8-EC08-AC85-7B71302B82BB}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="310276" y="4047000"/><a:ext cx="2350483" cy="904534"/></a:xfrm><a:prstGeom prst="flowChartProcess"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="50000"/></a:schemeClr></a:solidFill><a:ln/></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="t"/><a:lstStyle/><a:p><a:r><a:rPr lang="en-IN" sz="1200" b="1"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Benefits –</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-IN" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>No organisational disruption</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-IN" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Low regulatory risk</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buFont typeface="Arial" panose="020B0604020202020204" pitchFamily="34" charset="0"/><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="en-IN" sz="1050"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>Clear roadmap linked to measurable outcomes.</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-IN" sz="1200"><a:solidFill><a:schemeClr val="bg1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="11" name="Text 11"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{FAEFCAFA-D62C-9E27-C459-4B4DBAF5E45C}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="7377801" y="4960620"/><a:ext cx="1653804" cy="182880"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln/></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="0" indent="0"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="800" i="1"><a:solidFill><a:srgbClr val="888888"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri" pitchFamily="34" charset="-122"/><a:cs typeface="Calibri" pitchFamily="34" charset="-120"/></a:rPr><a:t>Greenfinch Consulting | Confidential</a:t></a:r><a:endParaRPr lang="en-US" sz="800"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="7" name="Text 24"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{A98091EB-6B82-0431-F077-72AE444B2942}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="8732520" y="4958968"/><a:ext cx="365760" cy="182880"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln/></p:spPr><p:txBody><a:bodyPr wrap="square" lIns="0" tIns="0" rIns="0" bIns="0" rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:pPr marL="0" indent="0" algn="r"><a:buNone/></a:pPr><a:r><a:rPr lang="en-US" sz="800" b="1"><a:solidFill><a:srgbClr val="888888"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/><a:ea typeface="Calibri"/><a:cs typeface="Calibri"/></a:rPr><a:t>12</a:t></a:r></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="1228321669"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>