p:cNvPr id="8" name="Rectangle 7"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{9478FA95-FEAB-F895-93DC-FC21B166A827}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="320040" y="4341541"/><a:ext cx="8407140" cy="623222"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:solidFill><a:schemeClr val="accent5"><a:lumMod val="20000"/><a:lumOff val="80000"/></a:schemeClr></a:solidFill></p:spPr><p:style><a:lnRef idx="1"><a:schemeClr val="accent5"/></a:lnRef><a:fillRef idx="2"><a:schemeClr val="accent5"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent5"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="dk1"/></a:fontRef></p:style><p:txBody><a:bodyPr rtlCol="0" anchor="ctr"/><a:lstStyle/><a:p><a:r><a:rPr lang="en-US" sz="1100"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We have served 150+ clients across 4 core services - technical valuation, legal, credit assessment, and collections. We processed ~24,000 technical, ~3,000 legal, and ~5,000 credit transactions / month. This scale was supported by a network of 600+ field executives and 450+ drafters across verticals, enabling consistent, TAT-driven delivery of high-quality reports across geographies.</a:t></a:r><a:endParaRPr lang="en-IN" sz="1100"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="9" name="TextBox 8"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{284EB1A1-14B8-71EC-42C2-7C808D92F6D3}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="221255" y="4007363"/><a:ext cx="6115048" cy="369332"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom>