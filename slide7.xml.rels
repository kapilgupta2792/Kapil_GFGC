000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:rPr><a:t>Management Immersion</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We own the outcomes of advise, with commitment to achieve and sharing of success. This we do through execution-focused on-going support. </a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We immerse senior leaders along with key L-1 experts to oversee Operations — working as a +1 to your existing leaders to ensure progress toward defined KPIs</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:r><a:rPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:rPr><a:t>We run a tight ship with structured governance and stay till KPIs are achieved..</a:t></a:r></a:p><a:p><a:endParaRPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="1600"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US"><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos" panose="020B0004020202020204" pitchFamily="34" charset="0"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr></a:p><a:p><a:endParaRPr lang="en-US" sz="2000" b="1"><a:solidFill><a:schemeClr val="accent1"/></a:solidFill><a:latin typeface="Aptos"/></a:endParaRPr